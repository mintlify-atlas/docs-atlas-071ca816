  "keyFeatures": [
    "Canvas/SVG-based rendering engine",
    "Rich text formatting (bold, italic, underline, strikeout, superscript/subscript)",
    "Table operations with cell merging and splitting",
    "Image handling with cropping and captions",
    "Form controls (select, text, date, radio, checkbox)",
    "Print and PDF export capabilities",
    "Header, footer, and page number support",
    "Watermark and pagination",
    "Search and replace functionality",
    "Undo/redo with history management",
    "Custom shortcuts and context menus",
    "Plugin system for extensibility",
    "Event bus for lifecycle hooks",
    "Internationalization (i18n) support",
    "Multiple editor modes (edit, readonly, print, form)",
    "List support (ordered and unordered)",
    "Hyperlink management",
    "Code blocks with syntax highlighting",
    "LaTeX formula support",
    "Comment and catalog features"
  ],
